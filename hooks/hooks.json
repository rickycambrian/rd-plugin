{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "tmp=$(mktemp); cat > \"$tmp\"; node ${CLAUDE_PLUGIN_ROOT}/dist/capture.mjs < \"$tmp\"; node ${CLAUDE_PLUGIN_ROOT}/dist/session-start.mjs < \"$tmp\"; rm -f \"$tmp\"",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "tmp=$(mktemp); cat > \"$tmp\"; node ${CLAUDE_PLUGIN_ROOT}/dist/capture.mjs < \"$tmp\"; node ${CLAUDE_PLUGIN_ROOT}/dist/task-context.mjs < \"$tmp\"; node ${CLAUDE_PLUGIN_ROOT}/dist/monitor-advisory.mjs < \"$tmp\"; rm -f \"$tmp\"",
            "timeout": 6
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/dist/ci-wait-guard.mjs",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/dist/capture.mjs",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/dist/capture.mjs",
            "timeout": 5
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/dist/capture.mjs",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/dist/capture.mjs",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/dist/capture.mjs --spawn-flush",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/dist/capture.mjs --spawn-flush --final",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
